[run]
branch = True
parallel = True
relative_files = True
source =
    app
omit =
    */tests/*
    */migrations/*
    backend/alembic/*

[report]
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    raise NotImplementedError
    if __name__ == "__main__":
    if __debug__:
    except ImportError:
show_missing = True

[paths]
source =
    app
    */site-packages/app
