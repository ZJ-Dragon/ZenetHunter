

# ---- ZenetHunter .dockerignore ----
# Goal: keep build context small & fast. See Docker docs on build context & .dockerignore.
#
# Monorepo layout: backend/ (Python), frontend/ (Node), deploy/, docs/
# This file ignores common caches, dependencies, build outputs, IDE files, and OS cruft.

############################
# VCS / meta
############################
.git
.git/
.gitmodules
.github/
.gitlab/

############################
# Node / frontend
############################
**/node_modules/
**/web_modules/
**/.pnp*
**/.yarn/*
**/dist/
**/build/
**/.next/
**/out/
**/.nuxt/
**/.output/
**/.svelte-kit/
**/.vite/
**/.vitepress/cache/
**/.vitepress/dist/
**/coverage/
**/*.tsbuildinfo
**/.eslintcache
**/.stylelintcache

############################
# Python / backend
############################
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.tox/
**/.nox/
**/.mypy_cache/
**/.ruff_cache/
**/.pytype/
**/.venv/
**/venv/
**/ENV/
**/env/
**/.eggs/
**/*.egg-info/
**/build/
**/dist/
/site/

############################
# Logs / reports
############################
**/*.log
logs/
report.*.json

############################
# OS files
############################
**/.DS_Store
**/Thumbs.db
**/Thumbs.db:encryptable
**/ehthumbs*.db
**/desktop.ini
nohup.out

############################
# IDE / Editor
############################
**/.idea/
**/.vscode/

############################
# Docs / misc (not needed for image build)
############################
docs/

# End of file
