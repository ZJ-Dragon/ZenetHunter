

# EditorConfig for ZenetHunter — keep styles consistent across editors
# See: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python follows PEP 8 (4 spaces)
[*.py]
indent_style = space
indent_size = 4

# TypeScript/JavaScript/JSX/TSX
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2

# JSON (package.json, etc.)
[*.json]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# TOML (pyproject.toml etc.)
[*.toml]
indent_style = space
indent_size = 2

# CSS/SCSS
[*.{css,scss}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Markdown: keep trailing spaces (CommonMark hard line breaks)
[*.{md,markdown}]
trim_trailing_whitespace = false

# Makefile requires literal tab for recipe lines
[Makefile]
indent_style = tab